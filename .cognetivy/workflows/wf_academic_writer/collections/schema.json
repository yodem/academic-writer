{
  "workflow_id": "wf_academic_writer",
  "kinds": {
    "run_input": {
      "name": "Run input",
      "description": "Initial article request: subject, selected source IDs, target word count",
      "item_schema": {
        "type": "object",
        "properties": {
          "subject": { "type": "string" },
          "sourceIds": { "type": "array", "items": { "type": "string" } },
          "wordCount": { "type": "number" },
          "citationStyle": { "type": "string", "enum": ["chicago", "mla", "apa"] }
        },
        "required": ["subject", "sourceIds"],
        "additionalProperties": true
      }
    },
    "validated_config": {
      "name": "Validated config",
      "description": "Validated sources and configuration after init step",
      "item_schema": { "type": "object", "additionalProperties": true }
    },
    "style_fingerprint": {
      "name": "Style Fingerprint",
      "description": "Researcher writing style analysis result",
      "item_schema": { "type": "object", "additionalProperties": true }
    },
    "source_material": {
      "name": "Source material",
      "description": "Retrieved chunks from RAG deep read",
      "item_schema": { "type": "object", "additionalProperties": true }
    },
    "thesis_options": {
      "name": "Thesis options",
      "description": "Proposed thesis statements for researcher selection",
      "item_schema": { "type": "object", "additionalProperties": true }
    },
    "selected_thesis": {
      "name": "Selected thesis",
      "description": "Researcher-approved thesis statement",
      "item_schema": { "type": "object", "additionalProperties": true }
    },
    "outline": {
      "name": "Outline",
      "description": "Generated article outline with sections",
      "item_schema": { "type": "object", "additionalProperties": true }
    },
    "approved_outline": {
      "name": "Approved outline",
      "description": "Researcher-approved article outline",
      "item_schema": { "type": "object", "additionalProperties": true }
    },
    "sync_result": {
      "name": "Sync result",
      "description": "Candlekeep to RAG sync status",
      "item_schema": { "type": "object", "additionalProperties": true }
    },
    "draft_sections": {
      "name": "Draft sections",
      "description": "Written article sections before audit",
      "item_schema": { "type": "object", "additionalProperties": true }
    },
    "audited_sections": {
      "name": "Audited sections",
      "description": "Sections with all citations verified",
      "item_schema": { "type": "object", "additionalProperties": true }
    },
    "final_draft": {
      "name": "Final draft",
      "description": "Synthesized and revised complete article",
      "item_schema": { "type": "object", "additionalProperties": true }
    },
    "article_file": {
      "name": "Article file",
      "description": "Output .docx file path and metadata",
      "item_schema": { "type": "object", "additionalProperties": true }
    }
  }
}
