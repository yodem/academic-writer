node_modules/

# OS
.DS_Store

# Python
__pycache__/
*.pyc

# Logs
logs/

# Local-only docs and HTML playgrounds (not part of plugin distribution)
*.html

# .claude - ignore runtime/session state; commit hooks, skills, and config
.claude/.comm-style-counter
.claude/.satisfaction-counter
.claude/cc10x/
.claude/context/
.claude/feedback/
.claude/hooks/metrics.json
