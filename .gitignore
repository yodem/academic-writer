.claude/memory/open-problems.jsonl
.claude/memory/sessions/
.claude/memory/tool-preferences.json
.claude/scheduled_tasks.lock

# Agent memory — runtime state per agent spawn, not part of plugin distribution
src/agents/memory/
plugins/academic-writer/agents/memory/


# cognetivy - ignore runtime data; commit workflows/*/versions/
.cognetivy/runs/
.cognetivy/events/
.cognetivy/collections/
.cognetivy/node-results/

# Voice profile build artifacts (only AUTHOR_VOICE.md is tracked)
.voice/*
!.voice/.gitkeep
