{
  "description": "Academic Writer hooks -- profile checks, fingerprint, session dashboard, and session logging (TypeScript/ESM)",
  "hooks": {
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/bin/run-hook.mjs lifecycle/session-end-log",
            "timeout": 10,
            "statusMessage": "Logging session..."
          }
        ]
      }
    ]
  }
}
